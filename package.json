{
  "name": "cemetery-management-system",
  "version": "1.0.0",
  "description": "小型墓园管理后端系统",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "init": "node scripts/init-db.js",
    "seed": "node scripts/seed-data.js",
    "migrate": "node scripts/migrate-db.js",
    "test": "node scripts/run-tests.js",
    "test:node": "node scripts/run-tests.js --node-only",
    "test:python": "node scripts/run-tests.js --python-only",
    "test:debug": "node scripts/run-tests.js --verbose --no-cleanup",
    "test:clean": "node -e \"const fs=require('fs');const path=require('path');const db=path.resolve(__dirname,'./data/test-cemetery.db');['','-shm','-wal','-journal'].forEach(s=>{const p=db+s;if(fs.existsSync(p)){fs.unlinkSync(p);console.log('Deleted:',p)}});const pid=path.resolve(__dirname,'./data/.test-server.pid');if(fs.existsSync(pid)){fs.unlinkSync(pid);console.log('Deleted:',pid)};console.log('Cleanup complete')\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
